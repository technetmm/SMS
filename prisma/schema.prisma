// Prisma schema for LMS

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
}

enum Plan {
  FREE
  BASIC
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
}

enum StaffStatus {
  ACTIVE
  ONLEAVE
  RESIGNED
  TERMINATED
}

enum ClassType {
  ONE_ON_ONE
  PRIVATE
  GROUP
}

enum ProgramType {
  REGULAR
  INTENSIVE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum BillingType {
  ONE_TIME
  MONTHLY
}

enum InvoiceType {
  ONE_TIME
  MONTHLY
}

enum DiscountType {
  NONE
  FIXED
  PERCENT
}

enum Currency {
  USD
  MMK
  THB
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  image            String?
  role             UserRole  @default(SCHOOL_ADMIN)
  schoolId         String?
  isSchoolOwner    Boolean   @default(false)
  passwordHash     String?
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?

  school         Tenant?              @relation(fields: [schoolId], references: [id])
  staffProfile   Staff?
  studentProfile Student?
  auditLogs      AuditLog[]
  accounts       Account[]
  sessions       Session[]
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  plan      Plan      @default(FREE)
  isActive  Boolean   @default(true)
  billingDayOfMonth Int @default(5)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  users           User[]
  staff           Staff[]
  students        Student[]
  subjects        Subject[]
  courses         Course[]
  courseSubjects  CourseSubject[]
  classes         Class[]
  sections        Section[]
  enrollments     Enrollment[]
  attendance      Attendance[]
  progresses      Progress[]
  invoices        Invoice[]
  payments        Payment[]
  refunds         Refund[]
  staffAttendance StaffAttendance[]
  subscriptions   Subscription[]
  branches        Branch[]
  auditLogs       AuditLog[]
  timetables      Timetable[]
  payrolls        Payroll[]
}

model Branch {
  id        String    @id @default(cuid())
  schoolId  String
  name      String
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  tenant   Tenant    @relation(fields: [schoolId], references: [id])
  students Student[]
  staff    Staff[]
  sections Section[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Subscription {
  id                   String             @id @default(cuid())
  schoolId             String
  stripeCustomerId     String             @unique
  stripeSubscriptionId String             @unique
  plan                 Plan
  status               SubscriptionStatus
  isActive             Boolean            @default(true)
  currentPeriodEnd     DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  isDeleted            Boolean            @default(false)
  deletedAt            DateTime?

  tenant Tenant @relation(fields: [schoolId], references: [id])
}

model Staff {
  id             String        @id @default(cuid())
  userId         String        @unique
  schoolId       String
  branchId       String?
  name           String
  jobTitle       String
  nrcNumber      String
  dob            DateTime
  email          String
  gender         Gender
  maritalStatus  MaritalStatus
  parmentAddress String?
  currentAddress String?
  phone          String?
  hireDate       DateTime
  exitDate       DateTime?
  status         StaffStatus   @default(ACTIVE)
  yearOfService  Int?
  remark         String?
  ratePerSection Decimal       @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?

  user           User              @relation(fields: [userId], references: [id])
  tenant         Tenant            @relation(fields: [schoolId], references: [id])
  branch         Branch?           @relation(fields: [branchId], references: [id])
  sections       SectionStaff[]
  attendanceLogs StaffAttendance[]
  timetables     Timetable[]
  payrolls       Payroll[]

  @@index([schoolId])
}

model Student {
  id         String        @id @default(cuid())
  userId     String?       @unique
  schoolId   String
  branchId   String?
  name       String
  gender     Gender
  dob        DateTime
  fatherName String?
  motherName String?
  phone      String?
  address    String?
  status     StudentStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  isDeleted  Boolean       @default(false)
  deletedAt  DateTime?

  user        User?        @relation(fields: [userId], references: [id])
  tenant      Tenant       @relation(fields: [schoolId], references: [id])
  branch      Branch?      @relation(fields: [branchId], references: [id])
  enrollments Enrollment[]
  invoices    Invoice[]

  @@index([schoolId])
}

model Subject {
  id        String    @id @default(cuid())
  name      String
  schoolId  String
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant  Tenant          @relation(fields: [schoolId], references: [id])
  courses CourseSubject[]

  @@unique([schoolId, name])
}

model Course {
  id        String    @id @default(cuid())
  name      String
  schoolId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  classes  Class[]
  subjects CourseSubject[]
  tenant   Tenant          @relation(fields: [schoolId], references: [id])

  @@unique([schoolId, name])
  @@index([schoolId])
}

model CourseSubject {
  id        String   @id @default(cuid())
  schoolId  String
  courseId  String
  subjectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [schoolId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([courseId, subjectId])
  @@index([schoolId])
  @@index([courseId])
  @@index([subjectId])
}

model Class {
  id          String      @id @default(cuid())
  schoolId    String
  name        String
  courseId    String
  classType   ClassType
  programType ProgramType
  billingType BillingType @default(ONE_TIME)
  fee         Decimal     @default(0)
  feeCurrency Currency    @default(MMK)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?

  course   Course    @relation(fields: [courseId], references: [id])
  tenant   Tenant    @relation(fields: [schoolId], references: [id])
  sections Section[]

  @@index([schoolId])
}

model StaffAttendance {
  id        String           @id @default(cuid())
  schoolId  String
  staffId   String
  sectionId String
  date      DateTime
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant  Tenant  @relation(fields: [schoolId], references: [id])
  staff   Staff   @relation(fields: [staffId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([staffId, sectionId, date])
  @@index([schoolId])
  @@index([staffId, date])
  @@index([sectionId, date])
}

model Timetable {
  id        String    @id @default(cuid())
  schoolId  String
  sectionId String
  staffId   String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  room      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [schoolId], references: [id])
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@index([schoolId])
  @@index([staffId, dayOfWeek])
  @@index([sectionId, dayOfWeek])
}

model Payroll {
  id            String   @id @default(cuid())
  schoolId      String
  staffId       String
  month         DateTime
  totalSections Int
  totalAmount   Decimal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant Tenant @relation(fields: [schoolId], references: [id])
  staff  Staff  @relation(fields: [staffId], references: [id])

  @@unique([staffId, month])
  @@index([schoolId])
  @@index([staffId])
  @@index([month])
}

model Section {
  id        String    @id @default(cuid())
  schoolId  String
  classId   String
  branchId  String?
  name      String
  room      String?
  capacity  Int       @default(30)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  class           Class             @relation(fields: [classId], references: [id])
  branch          Branch?           @relation(fields: [branchId], references: [id])
  tenant          Tenant            @relation(fields: [schoolId], references: [id])
  scheduleSlots   SectionSchedule[]
  enrollments     Enrollment[]
  staffAttendance StaffAttendance[]
  staffMappings   SectionStaff[]
  timetables      Timetable[]

  @@index([schoolId])
}

model SectionStaff {
  id        String   @id @default(cuid())
  sectionId String
  staffId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  staff   Staff   @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([sectionId, staffId])
  @@index([sectionId])
  @@index([staffId])
}

model SectionSchedule {
  id        String    @id @default(cuid())
  sectionId String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  room      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  section Section @relation(fields: [sectionId], references: [id])

  @@index([sectionId, dayOfWeek])
}

model Enrollment {
  id         String           @id @default(cuid())
  schoolId   String
  studentId  String
  sectionId  String
  billingType BillingType     @default(ONE_TIME)
  billingDayOfMonth Int       @default(5)
  monthlyBillingActive Boolean @default(false)
  monthlyStartYear Int?
  monthlyStartMonth Int?
  discountType DiscountType @default(NONE)
  discountValue Decimal @default(0)
  enrolledAt DateTime         @default(now())
  status     EnrollmentStatus @default(ACTIVE)
  isDeleted  Boolean          @default(false)
  deletedAt  DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  student    Student      @relation(fields: [studentId], references: [id])
  section    Section      @relation(fields: [sectionId], references: [id])
  tenant     Tenant       @relation(fields: [schoolId], references: [id])
  attendance Attendance[]
  progress   Progress[]
  invoices   Invoice[]

  @@unique([studentId, sectionId])
  @@index([schoolId])
}

model Attendance {
  id           String           @id @default(cuid())
  schoolId     String
  enrollmentId String
  date         DateTime
  status       AttendanceStatus
  isDeleted    Boolean          @default(false)
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [schoolId], references: [id])

  @@unique([enrollmentId, date])
  @@index([schoolId, date])
  @@index([enrollmentId])
}

model Progress {
  id           String    @id @default(cuid())
  schoolId     String
  enrollmentId String
  progress     Float
  remark       String?
  isDeleted    Boolean   @default(false)
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [schoolId], references: [id])

  @@unique([enrollmentId])
  @@index([schoolId])
  @@index([enrollmentId])
}

model Invoice {
  id             String        @id @default(cuid())
  schoolId       String
  studentId      String
  enrollmentId   String
  invoiceType    InvoiceType   @default(ONE_TIME)
  billingYear    Int?
  billingMonth   Int?
  originalAmount Decimal
  discount       Decimal       @default(0)
  finalAmount    Decimal
  paidAmount     Decimal       @default(0)
  status         PaymentStatus @default(UNPAID)
  dueDate        DateTime
  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  tenant     Tenant     @relation(fields: [schoolId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@unique([enrollmentId, billingYear, billingMonth])
  @@index([schoolId])
  @@index([studentId])
  @@index([enrollmentId])
}

model Payment {
  id        String   @id @default(cuid())
  schoolId  String
  invoiceId String
  amount    Decimal
  method    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  invoice   Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant    Tenant   @relation(fields: [schoolId], references: [id])
  refunds   Refund[]

  @@index([schoolId])
  @@index([invoiceId])
}

model Refund {
  id        String   @id @default(cuid())
  schoolId  String
  paymentId String
  amount    Decimal
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [schoolId], references: [id])

  @@index([schoolId])
  @@index([paymentId])
}

model AuditLog {
  id        String   @id @default(cuid())
  schoolId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [schoolId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([schoolId])
  @@index([userId])
  @@index([createdAt])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, token])
}
