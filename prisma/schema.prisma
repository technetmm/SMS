// Prisma schema for LMS

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  SCHOOL_ADMIN
  TEACHER
  STUDENT
}

enum Plan {
  FREE
  BASIC
  PREMIUM
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum MaritalStatus {
  SINGLE
  MARRIED
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
}

enum TeacherStatus {
  ACTIVE
  ONLEAVE
  RESIGNED
  TERMINATED
}

enum ClassType {
  ONE_ON_ONE
  PRIVATE
  GROUP
}

enum ProgramType {
  REGULAR
  INTENSIVE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum PaymentStatus {
  UNPAID
  PARTIAL
  PAID
}

enum Currency {
  USD
  MMK
  THB
}

enum Permission {
  MANAGE_STUDENTS
  MANAGE_TEACHERS
  MANAGE_CLASSES
  VIEW_REPORTS
  MANAGE_SUBSCRIPTIONS
  MANAGE_TENANTS
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  image            String?
  role             UserRole  @default(STUDENT)
  tenantId         String?
  passwordHash     String?
  twoFactorSecret  String?
  twoFactorEnabled Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)
  deletedAt        DateTime?

  tenant          Tenant?          @relation(fields: [tenantId], references: [id])
  teacherProfile  Teacher?
  studentProfile  Student?
  userPermissions UserPermission[]
  auditLogs       AuditLog[]
  accounts        Account[]
  sessions        Session[]
}

model Tenant {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  plan      Plan      @default(FREE)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  users              User[]
  teachers           Teacher[]
  students           Student[]
  subjects           Subject[]
  courses            Course[]
  courseSubjects     CourseSubject[]
  classes            Class[]
  sections           Section[]
  enrollments        Enrollment[]
  attendance         Attendance[]
  progresses         Progress[]
  invoices           Invoice[]
  payments           Payment[]
  refunds            Refund[]
  teacherAttendance  TeacherAttendance[]
  subscriptions      Subscription[]
  branches           Branch[]
  auditLogs          AuditLog[]
  timetables         Timetable[]
  payrolls           Payroll[]
}

model Branch {
  id        String    @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  students Student[]
  teachers Teacher[]
  sections Section[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String
  stripeCustomerId     String             @unique
  stripeSubscriptionId String             @unique
  plan                 Plan
  status               SubscriptionStatus
  isActive             Boolean            @default(true)
  currentPeriodEnd     DateTime
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  isDeleted            Boolean            @default(false)
  deletedAt            DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id])
}

model RolePermission {
  id         String     @id @default(cuid())
  role       UserRole
  permission Permission
  isDeleted  Boolean    @default(false)
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@unique([role, permission])
}

model UserPermission {
  id         String     @id @default(cuid())
  userId     String
  permission Permission
  isDeleted  Boolean    @default(false)
  deletedAt  DateTime?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
}

model Teacher {
  id             String        @id @default(cuid())
  userId         String        @unique
  tenantId       String
  branchId       String?
  name           String
  jobTitle       String
  nrcNumber      String
  dob            DateTime
  email          String
  gender         Gender
  maritalStatus  MaritalStatus
  parmentAddress String?
  currentAddress String?
  phone          String?
  hireDate       DateTime
  exitDate       DateTime?
  status         TeacherStatus @default(ACTIVE)
  yearOfService  Int?
  remark         String?
  ratePerSection Decimal       @default(0)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  isDeleted      Boolean       @default(false)
  deletedAt      DateTime?

  user     User             @relation(fields: [userId], references: [id])
  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  branch   Branch?          @relation(fields: [branchId], references: [id])
  sections SectionTeacher[]
  attendanceLogs TeacherAttendance[]
  timetables     Timetable[]
  payrolls       Payroll[]

  @@index([tenantId])
}

model Student {
  id         String        @id @default(cuid())
  userId     String?       @unique
  tenantId   String
  branchId   String?
  name       String
  gender     Gender
  dob        DateTime
  fatherName String?
  motherName String?
  phone      String?
  address    String?
  status     StudentStatus @default(ACTIVE)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  isDeleted  Boolean       @default(false)
  deletedAt  DateTime?

  user        User?        @relation(fields: [userId], references: [id])
  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  branch      Branch?      @relation(fields: [branchId], references: [id])
  enrollments Enrollment[]
  invoices    Invoice[]

  @@index([tenantId])
}

model Subject {
  id        String    @id @default(cuid())
  name      String
  tenantId  String
  isDeleted Boolean   @default(false)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  courses CourseSubject[]

  @@unique([tenantId, name])
}

model Course {
  id        String    @id @default(cuid())
  name      String
  tenantId  String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  classes  Class[]
  subjects CourseSubject[]
  tenant   Tenant    @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, name])
  @@index([tenantId])
}

model CourseSubject {
  id        String   @id @default(cuid())
  tenantId  String
  courseId  String
  subjectId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([courseId, subjectId])
  @@index([tenantId])
  @@index([courseId])
  @@index([subjectId])
}

model Class {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  courseId    String
  classType   ClassType
  programType ProgramType
  fee         Decimal     @default(0)
  feeCurrency Currency    @default(MMK)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  isDeleted   Boolean     @default(false)
  deletedAt   DateTime?

  course   Course    @relation(fields: [courseId], references: [id])
  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  sections Section[]

  @@index([tenantId])
}

model TeacherAttendance {
  id        String           @id @default(cuid())
  tenantId  String
  teacherId String
  sectionId String
  date      DateTime
  status    AttendanceStatus
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([teacherId, sectionId, date])
  @@index([tenantId])
  @@index([teacherId, date])
  @@index([sectionId, date])
}

model Timetable {
  id        String    @id @default(cuid())
  tenantId  String
  sectionId String
  teacherId String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  room      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([teacherId, dayOfWeek])
  @@index([sectionId, dayOfWeek])
}

model Payroll {
  id            String   @id @default(cuid())
  tenantId      String
  teacherId     String
  month         DateTime
  totalSections Int
  totalAmount   Decimal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  teacher Teacher @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, month])
  @@index([tenantId])
  @@index([teacherId])
  @@index([month])
}

model Section {
  id        String    @id @default(cuid())
  tenantId  String
  classId   String
  branchId  String?
  name      String
  room      String?
  capacity  Int       @default(30)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  class           Class             @relation(fields: [classId], references: [id])
  branch          Branch?           @relation(fields: [branchId], references: [id])
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  scheduleSlots   SectionSchedule[]
  enrollments     Enrollment[]
  teacherAttendance TeacherAttendance[]
  teacherMappings SectionTeacher[]
  timetables       Timetable[]

  @@index([tenantId])
}

model SectionTeacher {
  id        String   @id @default(cuid())
  sectionId String
  teacherId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([sectionId, teacherId])
  @@index([sectionId])
  @@index([teacherId])
}

model SectionSchedule {
  id        String    @id @default(cuid())
  sectionId String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  room      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  section Section @relation(fields: [sectionId], references: [id])

  @@index([sectionId, dayOfWeek])
}

model Enrollment {
  id        String           @id @default(cuid())
  tenantId  String
  studentId String
  sectionId String
  enrolledAt DateTime        @default(now())
  status    EnrollmentStatus @default(ACTIVE)
  isDeleted Boolean          @default(false)
  deletedAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  student    Student      @relation(fields: [studentId], references: [id])
  section    Section      @relation(fields: [sectionId], references: [id])
  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  attendance Attendance[]
  progress   Progress[]
  invoices   Invoice[]

  @@unique([studentId, sectionId])
  @@index([tenantId])
}

model Attendance {
  id           String           @id @default(cuid())
  tenantId     String
  enrollmentId String
  date         DateTime
  status       AttendanceStatus
  isDeleted    Boolean          @default(false)
  deletedAt    DateTime?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([enrollmentId, date])
  @@index([tenantId, date])
  @@index([enrollmentId])
}

model Progress {
  id           String   @id @default(cuid())
  tenantId     String
  enrollmentId String
  progress     Float
  remark       String?
  isDeleted    Boolean  @default(false)
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@unique([enrollmentId])
  @@index([tenantId])
  @@index([enrollmentId])
}

model Invoice {
  id           String        @id @default(cuid())
  tenantId     String
  studentId    String
  enrollmentId String
  originalAmount Decimal
  discount     Decimal       @default(0)
  finalAmount  Decimal
  paidAmount   Decimal       @default(0)
  status       PaymentStatus @default(UNPAID)
  dueDate      DateTime
  isDeleted    Boolean       @default(false)
  deletedAt    DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant     Tenant     @relation(fields: [tenantId], references: [id])
  student    Student    @relation(fields: [studentId], references: [id])
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@unique([enrollmentId])
  @@index([tenantId])
  @@index([studentId])
  @@index([enrollmentId])
}

model Payment {
  id            String        @id @default(cuid())
  tenantId      String
  invoiceId     String
  amount        Decimal
  method        String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  refunds       Refund[]

  @@index([tenantId])
  @@index([invoiceId])
}

model Refund {
  id        String   @id @default(cuid())
  tenantId  String
  paymentId String
  amount    Decimal
  reason    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([paymentId])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant? @relation(fields: [tenantId], references: [id])
  user   User?   @relation(fields: [userId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([createdAt])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, token])
}
