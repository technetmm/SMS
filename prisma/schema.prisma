// Prisma schema for LMS

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum StudentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
}

enum Subject {
  ENGLISH
  MYANMAR
}

enum ClassType {
  ONE_ON_ONE
  PRIVATE
  GROUP
}

enum ProgramType {
  REGULAR
  INTENSIVE
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  LEAVE
}

enum PaymentStatus {
  PAID
  UNPAID
}

enum DayOfWeek {
  MON
  TUE
  WED
  THU
  FRI
  SAT
  SUN
}

model User {
  id           String    @id @default(cuid())
  name         String?
  email        String    @unique
  image        String?
  role         UserRole  @default(STUDENT)
  passwordHash String?
  twoFactorSecret  String?
  twoFactorEnabled Boolean @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  teacherProfile Teacher?
  studentProfile Student?
  accounts       Account[]
  sessions       Session[]
}

model Teacher {
  id             String   @id @default(cuid())
  userId         String   @unique
  phone          String?
  ratePerSection Decimal  @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id])
  sections Section[]
}

model Student {
  id        String        @id @default(cuid())
  userId    String?       @unique
  name      String
  gender    Gender
  phone     String?
  status    StudentStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user        User?        @relation(fields: [userId], references: [id])
  enrollments Enrollment[]
  attendance  Attendance[]
  payments    Payment[]
}

model Course {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   Subject
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  classes Class[]
}

model Class {
  id          String      @id @default(cuid())
  name        String
  courseId    String
  classType   ClassType
  programType ProgramType
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  course   Course   @relation(fields: [courseId], references: [id])
  sections Section[]
}

model Section {
  id        String   @id @default(cuid())
  classId   String
  teacherId String?
  name      String
  room      String?
  capacity  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  class          Class            @relation(fields: [classId], references: [id])
  teacher        Teacher?         @relation(fields: [teacherId], references: [id])
  scheduleSlots  SectionSchedule[]
  enrollments    Enrollment[]
  attendanceLogs Attendance[]
}

model SectionSchedule {
  id        String    @id @default(cuid())
  sectionId String
  dayOfWeek DayOfWeek
  startTime String
  endTime   String
  room      String?

  section Section @relation(fields: [sectionId], references: [id])

  @@index([sectionId, dayOfWeek])
}

model Enrollment {
  id        String           @id @default(cuid())
  studentId String
  sectionId String
  status    EnrollmentStatus @default(ACTIVE)
  startDate DateTime          @default(now())
  endDate   DateTime?

  student Student @relation(fields: [studentId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([studentId, sectionId])
}

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  sectionId String
  date      DateTime
  status    AttendanceStatus

  student Student @relation(fields: [studentId], references: [id])
  section Section @relation(fields: [sectionId], references: [id])

  @@unique([studentId, sectionId, date])
  @@index([sectionId, date])
}

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  billingMonth  DateTime
  amount        Decimal
  deposit       Decimal?      @default(0)
  status        PaymentStatus @default(UNPAID)
  invoiceNumber String?       @unique
  paidAt        DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  student Student @relation(fields: [studentId], references: [id])

  @@index([studentId, billingMonth])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
