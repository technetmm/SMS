{
  "name": "lms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:status": "prisma migrate status",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "release:build-gate": "pnpm db:generate && pnpm build",
    "release:migration-gate": "pnpm db:migrate:status",
    "release:check": "pnpm release:build-gate && pnpm release:migration-gate",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app postgres redis",
    "docker:reset": "docker compose down -v",
    "docker:rebuild": "docker compose up --build -d",
    "docker:migrate": "docker compose --profile tools run --rm migrate",
    "prod:migrate": "dotenv -e .env.migrate -- prisma migrate dev",
    "prod:deploy": "dotenv -e .env.migrate -- prisma migrate deploy",
    "prod:status": "dotenv -e .env.migrate -- prisma migrate status",
    "prod:reset": "dotenv -e .env.migrate -- prisma migrate reset --force",
    "prod:seed": "dotenv -e .env.migrate -- prisma db seed",
    "uat:migrate": "dotenv -e .env.migrate.uat -- prisma migrate dev",
    "uat:deploy": "dotenv -e .env.migrate.uat -- prisma migrate deploy",
    "uat:status": "dotenv -e .env.migrate.uat -- prisma migrate status",
    "uat:reset": "dotenv -e .env.migrate.uat -- prisma migrate reset --force",
    "uat:seed": "dotenv -e .env.migrate.uat -- prisma db seed"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^3.9.0",
    "@next-auth/prisma-adapter": "^1.0.7",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "input-otp": "^1.4.2",
    "ioredis": "^5.7.0",
    "lucide-react": "^0.577.0",
    "next": "16.2.0",
    "next-auth": "^4.24.7",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.4",
    "otplib": "^12.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.52.2",
    "recharts": "^2.12.7",
    "shadcn": "^4.1.0",
    "sonner": "^1.7.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.11",
    "@types/pdfkit": "^0.17.3",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
